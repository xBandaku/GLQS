if $ARGS[0] = 'store_detail':
	!! Per-store category breakdown. Mirrors the store_buy dispatcher above,
	!! but exposes each category the store carries as its own button instead
	!! of buying everything in one shot.
	!! Capture before any nested gs call - $ARGS is one shared array in QSP,
	!! not scoped per gosub, so calling gs stat / gs themes below would
	!! clobber ARGS[1] before we get to read it.
	$glqs_store = $ARGS[1]
	menu_off = 0
	usehtml = 1
	$location_type = 'event'
	gs 'stat'
	gs 'themes', 'indoors'

	if $glqs_store = 'allure': $glqs_label = 'Allure'
	if $glqs_store = 'bomba': $glqs_label = 'Bomba'
	if $glqs_store = 'cats': $glqs_label = 'Pussy-Cats'
	if $glqs_store = 'coco': $glqs_label = 'Coco Carmen'
	if $glqs_store = 'danilovich': $glqs_label = 'Danilovich'
	if $glqs_store = 'dolls': $glqs_label = 'Patchwork Dolls'
	if $glqs_store = 'fancy': $glqs_label = 'Fancy Pancy'
	if $glqs_store = 'fashionista': $glqs_label = 'Fashionista'
	if $glqs_store = 'flamingos': $glqs_label = 'Flamingos'
	if $glqs_store = 'salacious': $glqs_label = 'Salacious (Exhibitionist)'
	if $glqs_store = 'gm': $glqs_label = 'G&M (all sub-lines)'
	if $glqs_store = 'market': $glqs_label = 'Market'
	if $glqs_store = 'materinstvo': $glqs_label = 'Materinstvo'
	if $glqs_store = 'moncheri': $glqs_label = 'Mon Cheri'
	if $glqs_store = 'nerdvana': $glqs_label = 'Nerdvana'
	if $glqs_store = 'scandalicious': $glqs_label = 'Scandalicious'
	if $glqs_store = 'eroto': $glqs_label = 'Eroto (Sex Shop)'
	if $glqs_store = 'lusso': $glqs_label = 'Lusso (underwear only)'
	if $glqs_store = 'misc': $glqs_label = 'Misc'
	$glqs_sicon = $func('$shop_icon_image', $glqs_store)

	'<center><img src="<<$glqs_sicon>>" height="80"><br><b><font color="maroon"><<$glqs_label>></font></b></center>'
	*nl
	'Pick a category to browse it item-by-item, or grab everything this store carries.'
	*nl

	if $glqs_store = 'allure':
		act 'Swimsuits': gt 'mod_GLQS_main', 'item_picker', 'clo', 'allure_swimsuit', 'allure', 'Swimsuits'
		act 'Bikinis': gt 'mod_GLQS_main', 'item_picker', 'clo', 'allure_bikinis', 'allure', 'Bikinis'
	end
	if $glqs_store = 'bomba':
		act 'Outfits': gt 'mod_GLQS_main', 'item_picker', 'clo', 'bomba_outfits', 'bomba', 'Outfits'
		act 'Dresses': gt 'mod_GLQS_main', 'item_picker', 'clo', 'bomba_dress', 'bomba', 'Dresses'
		act 'Shoes': gt 'mod_GLQS_main', 'item_picker', 'shoe', 'bomba', 'bomba', 'Shoes'
		act 'Coats': gt 'mod_GLQS_main', 'item_picker', 'coat', 'bomba', 'bomba', 'Coats'
		act 'Purses': gt 'mod_GLQS_main', 'item_picker', 'purse', 'bomba', 'bomba', 'Purses'
	end
	if $glqs_store = 'cats':
		act 'Outfits': gt 'mod_GLQS_main', 'item_picker', 'clo', 'cats_outfits', 'cats', 'Outfits'
		act 'Dresses': gt 'mod_GLQS_main', 'item_picker', 'clo', 'cats_dress', 'cats', 'Dresses'
		act 'Shoes': gt 'mod_GLQS_main', 'item_picker', 'shoe', 'cats', 'cats', 'Shoes'
		act 'Bras': gt 'mod_GLQS_main', 'item_picker', 'bra', 'cats', 'cats', 'Bras'
		act 'Panties': gt 'mod_GLQS_main', 'item_picker', 'panty', 'cats', 'cats', 'Panties'
		act 'Coats': gt 'mod_GLQS_main', 'item_picker', 'coat', 'cats', 'cats', 'Coats'
		act 'Purses': gt 'mod_GLQS_main', 'item_picker', 'purse', 'cats', 'cats', 'Purses'
	end
	if $glqs_store = 'coco':
		act 'Outfits': gt 'mod_GLQS_main', 'item_picker', 'clo', 'coco_outfits', 'coco', 'Outfits'
		act 'Dresses': gt 'mod_GLQS_main', 'item_picker', 'clo', 'coco_dress', 'coco', 'Dresses'
		act 'Purses': gt 'mod_GLQS_main', 'item_picker', 'purse', 'coco', 'coco', 'Purses'
	end
	if $glqs_store = 'danilovich':
		act 'Outfits': gt 'mod_GLQS_main', 'item_picker', 'clo', 'danilovich_outfits', 'danilovich', 'Outfits'
		act 'Swimsuits': gt 'mod_GLQS_main', 'item_picker', 'clo', 'danilovich_swimsuit', 'danilovich', 'Swimsuits'
