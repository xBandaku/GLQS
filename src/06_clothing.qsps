!! CLOTHING MENU + STORE SUBMENU + STORE_BUY DISPATCHER
if $ARGS[0] = 'clothing_menu':
	menu_off = 0
	usehtml = 1
	$location_type = 'event'
	gs 'stat'
	gs 'themes', 'indoors'
	'<center><b><font color="maroon">Clothing & Accessories</font></b></center>'
	*nl
	'Buy out everything, or pick a single store from the submenu below. Items are granted at full durability so no tailor resize is needed.'
	*nl

	act 'Give Everything (all stores)':
		gs 'mod_GLQS_main', 'clothing'
		gt 'mod_GLQS_main', 'clothing_menu'
	end

	act 'Buy By Store': gt 'mod_GLQS_main', 'store_menu'

	act 'Return to Top Menu': gt 'mod_GLQS_main', 'start'
end


if $ARGS[0] = 'store_menu':
	menu_off = 0
	usehtml = 1
	$location_type = 'event'
	gs 'stat'
	gs 'themes', 'indoors'
	'<center><b><font color="maroon">Buy By Store</font></b></center>'
	*nl
	'Pick a store to buy out just that store''s stock.'
	*nl

	act 'Allure': gt 'mod_GLQS_main', 'store_detail', 'allure'
	act 'Bomba': gt 'mod_GLQS_main', 'store_detail', 'bomba'
	act 'Pussy-Cats': gt 'mod_GLQS_main', 'store_detail', 'cats'
	act 'Coco Carmen': gt 'mod_GLQS_main', 'store_detail', 'coco'
	act 'Danilovich': gt 'mod_GLQS_main', 'store_detail', 'danilovich'
	act 'Patchwork Dolls': gt 'mod_GLQS_main', 'store_detail', 'dolls'
	act 'Fancy Pancy': gt 'mod_GLQS_main', 'store_detail', 'fancy'
	act 'Fashionista': gt 'mod_GLQS_main', 'store_detail', 'fashionista'
	act 'Flamingos': gt 'mod_GLQS_main', 'store_detail', 'flamingos'
	act 'Salacious (Exhibitionist)': gt 'mod_GLQS_main', 'store_detail', 'salacious'
	act 'G&M (all sub-lines)': gt 'mod_GLQS_main', 'store_detail', 'gm'
	act 'Market': gt 'mod_GLQS_main', 'store_detail', 'market'
	act 'Materinstvo': gt 'mod_GLQS_main', 'store_detail', 'materinstvo'
	act 'Mon Cheri': gt 'mod_GLQS_main', 'store_detail', 'moncheri'
	act 'Nerdvana': gt 'mod_GLQS_main', 'store_detail', 'nerdvana'
	act 'Scandalicious': gt 'mod_GLQS_main', 'store_detail', 'scandalicious'
	act 'Eroto (Sex Shop)': gt 'mod_GLQS_main', 'store_detail', 'eroto'
	act 'Lusso (underwear only)': gt 'mod_GLQS_main', 'store_detail', 'lusso'
	act 'Misc': gt 'mod_GLQS_main', 'store_detail', 'misc'

	act 'Return': gt 'mod_GLQS_main', 'clothing_menu'
	act 'Return to Top Menu': gt 'mod_GLQS_main', 'start'
end


if $ARGS[0] = 'store_buy':
	!! Buys out every category a given store/brand carries, matching the games
	!! actual catalog (not every store sells every category).
	!! Uses separate if-blocks per store rather than one elseif chain.
	if $ARGS[1] = 'allure':
		gs 'mod_GLQS_main', 'fill_clo', 'allure_swimsuit'
		gs 'mod_GLQS_main', 'fill_clo', 'allure_bikinis'
	end
	if $ARGS[1] = 'bomba':
		gs 'mod_GLQS_main', 'fill_clo', 'bomba_outfits'
