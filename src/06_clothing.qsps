if $ARGS[0] = 'item_picker':
	!! Image-grid item picker, same pattern as the tattoo/piercing design
	!! pickers - shows every item in a category so a specific one can be
	!! clicked instead of buying the whole category in one shot.
	!! ARGS[1] = item type: clo / shoe / bra / panty / body / coat / purse
	!! ARGS[2] = key - full category name for clo (e.g. allure_swimsuit),
	!!           bare store name for every other type (e.g. bomba)
	!! ARGS[3] = store - bare store name, used only for the Return button
	!! ARGS[4] = label - display name for the category (e.g. Swimsuits)
	!! All captured before any nested gs call - $ARGS and total are both
	!! plain globals in QSP, clobbered by any nested gs call.
	$glqs_ptype = $ARGS[1]
	$glqs_pkey = $ARGS[2]
	$glqs_pstore = $ARGS[3]
	$glqs_plabel = $ARGS[4]

	if $glqs_ptype = 'clo': gs 'clothing', 'totals', $glqs_pkey
	if $glqs_ptype = 'shoe': gs 'shoes', 'totals', $glqs_pkey + '_shoe'
	if $glqs_ptype = 'bra': gs 'bras', 'totals', $glqs_pkey + '_bras'
	if $glqs_ptype = 'panty': gs 'panties', 'totals', $glqs_pkey + '_panties'
	if $glqs_ptype = 'body': gs 'underwear_bodysuits', 'totals', $glqs_pkey + '_bodysuits'
	if $glqs_ptype = 'coat': gs 'coats', 'totals', $glqs_pkey + '_coats'
	if $glqs_ptype = 'purse': gs 'purses', 'totals', $glqs_pkey + '_purses'
	glqs_ptotal = total
	$glqs_picon = $func('$shop_icon_image', $glqs_pkey)

	menu_off = 0
	usehtml = 1
	$location_type = 'event'
	gs 'stat'
	gs 'themes', 'indoors'

	'<center><img src="<<$glqs_picon>>" height="80"><br><b><font color="maroon"><<$glqs_plabel>></font></b></center>'
	'<br><<glqs_ptotal>> items available. Click an image to add it to your wardrobe at full durability.'
	*nl

	$glqs_grid = '<div style="display:flex; flex-wrap:wrap; gap:8px;">'
	glqs_i = 1
	:glqs_item_picker_loop
	if glqs_i <= glqs_ptotal:
		if $glqs_ptype = 'clo': $glqs_pimg = $func('$clothing_image', $glqs_pkey, glqs_i)
		if $glqs_ptype = 'shoe': $glqs_pimg = $func('$shoe_image', $glqs_pkey, glqs_i)
		if $glqs_ptype = 'bra': $glqs_pimg = $func('$bra_image', $glqs_pkey, glqs_i)
		if $glqs_ptype = 'panty': $glqs_pimg = $func('$panty_image', $glqs_pkey, glqs_i)
		if $glqs_ptype = 'body': $glqs_pimg = $func('$bodysuit_image', $glqs_pkey, glqs_i)
		if $glqs_ptype = 'coat': $glqs_pimg = $func('$coat_image', $glqs_pkey, glqs_i)
		if $glqs_ptype = 'purse': $glqs_pimg = $func('$purse_image', $glqs_pkey, glqs_i)

		$glqs_grid += '<div style="flex:0 0 auto;"><a href="exec: gs ''mod_GLQS_main'', ''item_pick'', ''<<$glqs_ptype>>'', ''<<$glqs_pkey>>'', <<glqs_i>> & gs ''stat'' & gt ''mod_GLQS_main'', ''item_picker'', ''<<$glqs_ptype>>'', ''<<$glqs_pkey>>'', ''<<$glqs_pstore>>'', ''<<$glqs_plabel>>''"><img height="220" src="<<$glqs_pimg>>"></a></div>'

		glqs_i += 1
		jump 'glqs_item_picker_loop'
	end
	killvar 'glqs_i'
	$glqs_grid += '</div>'
	$glqs_grid
	*nl

	act 'Give All (this category)':
		gs 'mod_GLQS_main', 'item_pick_all', $glqs_ptype, $glqs_pkey
		gt 'mod_GLQS_main', 'item_picker', $glqs_ptype, $glqs_pkey, $glqs_pstore, $glqs_plabel
	end
	act 'Return': gt 'mod_GLQS_main', 'store_detail', $glqs_pstore
	act 'Return to Top Menu': gt 'mod_GLQS_main', 'start'
end


if $ARGS[0] = 'item_pick':
	!! Grants a single item at ARGS[3] within category ARGS[2] of type ARGS[1].
	!! Mirrors the per-type grant logic in fill_clo/fill_shoe/etc in
	!! 16_fill_helpers.qsps, but for one index instead of looping over all.
	$glqs_ip_type = $ARGS[1]
	$glqs_ip_key = $ARGS[2]
	glqs_ip_idx = ARGS[3]

	if $glqs_ip_type = 'clo':
		dyneval('<<$glqs_ip_key>>[glqs_ip_idx] = 1')
		gs 'clothing_attributes', $glqs_ip_key, glqs_ip_idx
		dyneval('<<$glqs_ip_key>>_h[glqs_ip_idx] = CloMaxStrength')
	end
	if $glqs_ip_type = 'shoe':
		dyneval('<<$glqs_ip_key>>_shoe[glqs_ip_idx] = 1')
		gs 'shoe_attributes', $glqs_ip_key, glqs_ip_idx
		dyneval('<<$glqs_ip_key>>_shoe_h[glqs_ip_idx] = ShoMaxStrength')
	end
	if $glqs_ip_type = 'bra':
		dyneval('<<$glqs_ip_key>>_bras[glqs_ip_idx] = 1')
		gs 'underwear_attributes', $glqs_ip_key + '_bras', glqs_ip_idx
		dyneval('<<$glqs_ip_key>>_bras_h[glqs_ip_idx] = BraMaxStrength')
	end
	if $glqs_ip_type = 'panty':
		dyneval('<<$glqs_ip_key>>_panties[glqs_ip_idx] = 1')
		gs 'underwear_attributes', $glqs_ip_key + '_panties', glqs_ip_idx
		dyneval('<<$glqs_ip_key>>_panties_h[glqs_ip_idx] = PanMaxStrength')
	end
	if $glqs_ip_type = 'body':
		dyneval('<<$glqs_ip_key>>_bodysuits[glqs_ip_idx] = 1')
		gs 'underwear_attributes', $glqs_ip_key + '_bodysuits', glqs_ip_idx
		dyneval('<<$glqs_ip_key>>_bodysuits_h[glqs_ip_idx] = BraMaxStrength')
	end
	if $glqs_ip_type = 'coat':
		dyneval('<<$glqs_ip_key>>_coats[glqs_ip_idx] = 1')
		gs 'coat_attributes', $glqs_ip_key, glqs_ip_idx
		dyneval('<<$glqs_ip_key>>_coats_h[glqs_ip_idx] = CoatMaxStrength')
	end
	if $glqs_ip_type = 'purse':
		dyneval('<<$glqs_ip_key>>_purses[glqs_ip_idx] = 1')
	end

	killvar '$glqs_ip_type'
	killvar '$glqs_ip_key'
	killvar 'glqs_ip_idx'
end


if $ARGS[0] = 'item_pick_all':
	!! Convenience bulk option inside the picker - grants every item in the
	!! category by dispatching to the existing fill_* helper for the type.
	$glqs_ipa_type = $ARGS[1]
	$glqs_ipa_key = $ARGS[2]
	if $glqs_ipa_type = 'clo': gs 'mod_GLQS_main', 'fill_clo', $glqs_ipa_key
	if $glqs_ipa_type = 'shoe': gs 'mod_GLQS_main', 'fill_shoe', $glqs_ipa_key
	if $glqs_ipa_type = 'bra': gs 'mod_GLQS_main', 'fill_bra', $glqs_ipa_key
	if $glqs_ipa_type = 'panty': gs 'mod_GLQS_main', 'fill_panty', $glqs_ipa_key
	if $glqs_ipa_type = 'body': gs 'mod_GLQS_main', 'fill_body', $glqs_ipa_key
	if $glqs_ipa_type = 'coat': gs 'mod_GLQS_main', 'fill_coat', $glqs_ipa_key
	if $glqs_ipa_type = 'purse': gs 'mod_GLQS_main', 'fill_purse', $glqs_ipa_key
	killvar '$glqs_ipa_type'
	killvar '$glqs_ipa_key'
end


