		act 'Purses': gt 'mod_GLQS_main', 'item_picker', 'purse', 'dolls', 'dolls', 'Purses'
	end
	if $glqs_store = 'fancy':
		act 'Burlesque Outfits': gt 'mod_GLQS_main', 'item_picker', 'clo', 'fancy_burlesque', 'fancy', 'Burlesque Outfits'
	end
	if $glqs_store = 'fashionista':
		act 'Outfits': gt 'mod_GLQS_main', 'item_picker', 'clo', 'fashionista_outfits', 'fashionista', 'Outfits'
		act 'Dresses': gt 'mod_GLQS_main', 'item_picker', 'clo', 'fashionista_dress', 'fashionista', 'Dresses'
